# Copy this file to .env.local (already gitignored) and fill in your own values from
# Supabase project Settings > API. VITE_SUPABASE_ANON_KEY is safe to expose publicly
# (that's the whole point of the anon key) — just don't commit .env.local anyway, so
# nobody mistakes it for the secret service_role key, which must never go in this file
# or anywhere client-side.
#
# If these are left unset, the app runs entirely local-first (localStorage only), same
# as before there was a backend.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Only needed locally to run scripts/export-feedback.ts. This is the SECRET
# service_role key (Project Settings > API), not the anon key above. Never
# prefix it with VITE_ (that would ship it in the client bundle) and never
# commit it or paste it into a chat session.
SUPABASE_SERVICE_ROLE_KEY=
